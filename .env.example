# =============================================================================
# Enervera Medical GraphRAG — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your real credentials.
# Variables marked REQUIRED must be set or the application will refuse to start.
# Variables marked OPTIONAL fall back to the listed default.
# =============================================================================

# -----------------------------------------------------------------------------
# HTTP service (FastAPI on Render)
# -----------------------------------------------------------------------------
# OPTIONAL — port the uvicorn server binds to. Render injects this automatically.
PORT=8000

# OPTIONAL — log verbosity: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# OPTIONAL — when set, /chat and /episodic routes require X-API-Key matching.
# Leave blank for an open API (internal use only).
API_KEY=

# OPTIONAL — comma-separated CORS origins for the frontend. "*" allows any.
# Tighten this to your real frontend URL(s) in production:
#   CORS_ORIGINS=https://app.enervera.com,https://staging.enervera.com
# Health, /metrics and /docs are always public regardless of this setting.
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Pinecone (vector index)
# -----------------------------------------------------------------------------
# REQUIRED — Pinecone API key (https://app.pinecone.io/)
PINECONE_API_KEY=

# OPTIONAL — Pinecone index name. Default: enervera
PINECONE_INDEX_NAME=enervera

# -----------------------------------------------------------------------------
# Neo4j (knowledge graph) — currently hosted on Neo4j Aura
# -----------------------------------------------------------------------------
# REQUIRED — Neo4j connection URI.
#   Aura  →  neo4j+s://<dbid>.databases.neo4j.io   (TLS + routing, recommended)
#   Aura  →  neo4j+ssc://<dbid>.databases.neo4j.io (TLS, self-signed-cert variant)
#   Local →  bolt://127.0.0.1:7687
# Grab the Aura URI from the "Connection URI" field on your instance page.
NEO4J_URI=neo4j+s://<your-aura-dbid>.databases.neo4j.io

# OPTIONAL — Neo4j username. Aura defaults to `neo4j` on the free tier.
NEO4J_USERNAME=neo4j

# REQUIRED — Neo4j password. Aura shows it once at instance creation; if you
# lost it, reset from the Aura console (this rotates the credential).
NEO4J_PASSWORD=

# -----------------------------------------------------------------------------
# Google Gemini (LLM — answer, classifier, analyzer, extraction, cleaning)
# -----------------------------------------------------------------------------
# REQUIRED — Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# OPTIONAL — every model role defaults to gemini-2.5-flash-lite. If Lite's
# free-tier quota becomes a problem, override individual roles (or all of
# them) to gemini-2.5-flash here.
# ANSWER_MODEL=gemini-2.5-flash-lite
# EXTRACTION_MODEL=gemini-2.5-flash-lite
# CLEANING_MODEL=gemini-2.5-flash-lite
# CLASSIFIER_MODEL=gemini-2.5-flash-lite
# QUERY_ANALYZER_MODEL=gemini-2.5-flash-lite
# SUMMARIZATION_MODEL=gemini-2.5-flash-lite

# -----------------------------------------------------------------------------
# Episodic memory (Pinecone-backed, isolated from longitudinal Postgres)
# -----------------------------------------------------------------------------
# Pinecone index name used by the episodic memory layer.
PINECONE_EPISODIC_INDEX_NAME=episodicmemory

# -----------------------------------------------------------------------------
# Redis (session memory — optional; falls back to in-memory store)
# -----------------------------------------------------------------------------
# OPTIONAL — Redis connection URL. Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# OPTIONAL — Session time-to-live in seconds. Default: 7200 (2 hours)
SESSION_TTL_SEC=7200

# -----------------------------------------------------------------------------
# PostgreSQL (longitudinal memory — canonical store)
# -----------------------------------------------------------------------------
# REQUIRED for the new memory/ subsystem.
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/enervera

# OPTIONAL — Patient-state hot cache TTL in seconds. Default: 300 (5 minutes).
MEMORY_CACHE_TTL_SEC=300
