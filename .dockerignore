# Version control
.git/
.gitignore
.github/

# Python caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/

# Coverage
.coverage
.coverage.*
coverage.xml
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Secrets (never copy local env into the image)
.env
.env.local
.env.*.local

# Local runtime data (mount as volumes instead of baking in)
logs/
chunking/output/
data/
documents/

# Docs and dev-only files
docs/
tests/
*.md
!README.md

# IDE
.vscode/
.idea/

# This file
.dockerignore
