# --------------------------------------------------------------------------
# Python bytecode and caches
# --------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# --------------------------------------------------------------------------
# Virtual environments
# --------------------------------------------------------------------------
.venv/
venv/
env/

# --------------------------------------------------------------------------
# Build artifacts
# --------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/

# --------------------------------------------------------------------------
# Tool caches
# --------------------------------------------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/

# --------------------------------------------------------------------------
# Coverage
# --------------------------------------------------------------------------
.coverage
.coverage.*
coverage.xml
htmlcov/

# --------------------------------------------------------------------------
# Secrets and local config
# --------------------------------------------------------------------------
.env
.env.local
.env.*.local

# --------------------------------------------------------------------------
# Runtime artifacts
# --------------------------------------------------------------------------
logs/
chunking/output/

# --------------------------------------------------------------------------
# IDE / editor
# --------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# --------------------------------------------------------------------------
# Frontend / static assets (this repo ships an API-only service — any HTML,
# bundled JS, or test UI is treated as out-of-tree. A separately hosted
# frontend integrates via docs/FRONTEND.md, not by being committed here.)
# --------------------------------------------------------------------------
app/static/
static/
*.html
*.htm

# --------------------------------------------------------------------------
# Local notes / scratch
# --------------------------------------------------------------------------
*.local.md
scratch/
tmp/
